# --- Servidor Minecraft ---
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=AiBot
# Deixa vazio para auto-detectar a versao do servidor
MC_VERSION=
# offline = servidor sem autenticacao (cracked/local)
MC_AUTH=offline

# --- IA gratuita (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- IA paga opcional (Hack Club AI) ---
# Ativa apenas se tiveres uma chave API
HACKCLUB_ENABLED=false
HACKCLUB_API_KEY=
HACKCLUB_SERVER_URL=https://ai.hackclub.com/proxy/v1
HACKCLUB_MODEL=qwen/qwen3-32b

# --- Orcamento mensal (apenas para Hack Club AI) ---
MONTHLY_BUDGET_EUR=3.0
EST_COST_PER_1K_TOKENS_EUR=0.00015
USD_TO_EUR_RATE=0.93

# --- Geral ---
LOG_LEVEL=info
BOT_LANGUAGE=pt
